# Copy to `.env` and fill in. The `web-server` binary refuses to start
# unless DEFCROW_SESSION_SECRET is set; everything else has a sane
# default for local development.

# REQUIRED — HMAC secret used to sign session JWTs. Rotate on deploy
# to invalidate every outstanding session (the claim schema version
# also gates this — see SESSION_CLAIMS_VERSION in middleware/auth.rs).
DEFCROW_SESSION_SECRET=defcrow-test-secret-32chars-min!!

# Port to bind. Defaults to 8080.
DEFCROW_PORT=8080

# Where one-time artifacts, staged shellcode, users.json and
# auth_settings.json all live. Should be a directory the server can
# create + write to.
DEFCROW_ARTIFACTS_DIR=/tmp/defcrow-artifacts

# Username seeded into ${DEFCROW_ARTIFACTS_DIR}/users.json on first
# run (when users.json does not yet exist). Defaults to "admin".
DEFCROW_BOOTSTRAP_USERNAME=admin

# Optional — Discord webhook URL seeded into auth_settings.json on
# first run (when auth_settings.json does not yet exist). Lets a
# fresh deployment escape the chicken-and-egg of needing to log in
# to configure the webhook that delivers the login key. Must be
# rooted at https://discord.com/api/webhooks/ — anything else is
# rejected at startup.
# DEFCROW_BOOTSTRAP_WEBHOOK=https://discord.com/api/webhooks/...
